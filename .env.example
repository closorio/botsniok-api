# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Cloud Translate
GOOGLE_APPLICATION_CREDENTIALS=./google_translate_apikey.json

# Channel Configuration
# Multi-source: comma-separated channel IDs
SOURCE_CHANNEL_IDS=-100123456789
# Backward compatible alternative (single source):
# AUX_CHANNEL_ID=-100123456789

# Destination channels (comma-separated)
PRIVATE_CHANNEL_IDS=-100987654321

# Translation
TARGET_LANGUAGE=es

# Language detection: skip translation if text is already in target language
SKIP_SAME_LANGUAGE=true

# API Security
API_KEY=your_secure_api_key_here

# Telegram User Whitelist (comma-separated user IDs)
ALLOWED_TELEGRAM_IDS=123456789,987654321

# Deduplication window (hours)
DEDUP_WINDOW_HOURS=24

# Inline voting buttons on forwarded messages
SHOW_INLINE_BUTTONS=false

# Scheduled message: send pinned message from source channel daily at this time (HH:mm)
# Leave empty to disable
SCHEDULED_MESSAGE_TIME=

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
